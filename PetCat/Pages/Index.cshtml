@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio - Control Veterinario";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-success">🐾 Registro de Mascotas y Vacunas</h1>
        <p class="lead text-muted">Accede rápidamente a los formularios de registro y control clínico.</p>
        <hr class="w-25 mx-auto text-success" style="height: 3px;">
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-5">
            <div class="card h-100 shadow border-2 border-success bg-white">
                <div class="card-body d-flex flex-column p-4">
                    <div class="d-flex align-items-center mb-3">
                        <span class="fs-1 me-3">➕🐶</span>
                        <div>
                            <h4 class="card-title m-0 fw-bold text-success">Nueva Mascota</h4>
                            <small class="text-muted">Formulario de alta</small>
                        </div>
                    </div>
                    <p class="card-text text-secondary flex-grow-1">
                        Ingresa al formulario para registrar un nuevo paciente en el sistema (Nombre, raza, edad y datos del dueño).
                    </p>
                    <div class="d-grid mt-3">
                        <a asp-page="/MascotaPages/Create" class="btn btn-success btn-lg fw-semibold shadow-sm">
                            📝 Registrar Mascota
                        </a>
                    </div>
                    <div class="text-center mt-2">
                        <a asp-page="/MascotaPages/Index" class="text-decoration-none small text-muted">Ver lista de mascotas existentes →</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 shadow border-0 bg-light">
                <div class="card-body d-flex flex-column p-4">
                    <div class="d-flex align-items-center mb-3">
                        <span class="fs-1 me-3">💉🗓️</span>
                        <div>
                            <h4 class="card-title m-0 fw-bold text-dark">Nueva Vacuna</h4>
                            <small class="text-muted">Calendario y dosis</small>
                        </div>
                    </div>
                    <p class="card-text text-secondary flex-grow-1">
                        Registra la aplicación de una nueva vacuna, define la fecha, el tipo de dosis y la próxima fecha de refuerzo.
                    </p>
                    <div class="d-grid mt-3">
                        <a asp-page="/VacunaPages/Create" class="btn btn-primary btn-lg fw-semibold shadow-sm">
                            🧪 Registrar Vacuna
                        </a>
                    </div>
                    <div class="text-center mt-2">
                        <a asp-page="/VacunaPages/Index" class="text-decoration-none small text-muted">Ver historial completo →</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>