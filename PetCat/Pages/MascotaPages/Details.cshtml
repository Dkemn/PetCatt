@page
@model PetCat.Pages.MascotaPages.DetailsModel
@{
    ViewData["Title"] = "Historial Clínico";
}

<div class="container my-5 details-container">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="display-5 fw-bold text-dark m-0">📋 Ficha de Paciente</h1>
            <p class="text-muted m-0">Consulta la información general y el estado de vacunación.</p>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-page="./Edit" asp-route-id="@Model.Mascota.Id" class="btn btn-primary px-4 fw-semibold">
                ✏️ Editar Perfil
            </a>
            <a asp-page="./Index" class="btn btn-outline-secondary px-3">
                Volver
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-3 text-center h-100 bg-white">
                <div class="card-header bg-success text-white py-4 border-0">
                    <span class="display-1 d-block mb-2">🐾</span>
                    <h3 class="fw-bold m-0">@Html.DisplayFor(model => model.Mascota.Nombre)</h3>
                    <span class="badge bg-light text-success fw-bold px-3 py-2 mt-2 border">
                        @Html.DisplayFor(model => model.Mascota.Especie)
                    </span>
                </div>
                <div class="card-body p-4 text-start">
                    <div class="mb-3 border-bottom pb-2">
                        <small class="text-muted d-block fw-semibold">@Html.DisplayNameFor(model => model.Mascota.Raza)</small>
                        <span class="text-dark fw-medium">@Html.DisplayFor(model => model.Mascota.Raza)</span>
                    </div>
                    <div class="mb-3 border-bottom pb-2">
                        <small class="text-muted d-block fw-semibold">@Html.DisplayNameFor(model => model.Mascota.FechaNacimiento)</small>
                        <span class="text-dark">📅 @Html.DisplayFor(model => model.Mascota.FechaNacimiento)</span>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted d-block fw-semibold">@Html.DisplayNameFor(model => model.Mascota.Sexo)</small>
                        <span class="text-dark fw-bold">@Html.DisplayFor(model => model.Mascota.Sexo)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3 h-100 bg-white">
                <div class="card-header bg-light py-3 d-flex justify-content-between align-items-center border-bottom">
                    <h4 class="m-0 fw-bold text-dark">💉 Historial de Vacunas</h4>
                    <a asp-page="/VacunaPages/Create" asp-route-MascotaId="@Model.Mascota.Id" class="btn btn-success btn-sm fw-semibold shadow-sm">
                        ➕ Agregar Vacuna
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (Model.Mascota.Vacunas != null && Model.Mascota.Vacunas.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 custom-table">
                                <thead class="table-light text-secondary fw-semibold">
                                    <tr>
                                        <th class="ps-4">Nombre de la Vacuna</th>
                                        <th>Fecha Aplicación</th>
                                        <th>Próxima Dosis</th>
                                        <th class="text-center pe-4">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var vacuna in Model.Mascota.Vacunas)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">🧪 @vacuna.Nombre</td>
                                            <td class="text-secondary">@vacuna.FechaAplicacion.ToShortDateString()</td>
                                            <td>
                                                <span class="badge bg-warning text-dark px-2 py-1">
                                                    🗓️ @vacuna.FechaProximaDosis.ToShortDateString()
                                                </span>
                                            </td>
                                            <td class="text-center pe-4">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a asp-page="/VacunaPages/Edit" asp-route-id="@vacuna.Id" class="btn btn-outline-secondary px-2" title="Editar">✏️</a>
                                                    <a asp-page="/VacunaPages/Delete" asp-route-id="@vacuna.Id" class="btn btn-outline-danger px-2" title="Eliminar">❌</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-5 text-muted">
                            <span class="fs-1 d-block mb-2">🛡️</span>
                            <p class="mb-0 fw-medium">Esta mascota aún no tiene vacunas registradas en el sistema.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="text-start mt-4">
        <a asp-page="/Index" class="text-decoration-none text-muted small">← Volver al Panel Principal</a>
    </div>
</div>

<style>
    /* Animación de entrada de la ficha completa */
    .details-container {
        animation: fadeInDetails 0.4s ease-out;
    }

    /* Ajustes visuales de la tabla de vacunas */
    .custom-table tbody tr {
        transition: background-color 0.15s ease-in-out;
    }

        .custom-table tbody tr:hover {
            background-color: #fcfdfe !important;
        }

    /* Redondeado extra para las tarjetas */
    .rounded-3 {
        border-radius: 12px !important;
    }

    /* Doble @@ para escapar el motor Razor de ASP.NET Core */
    @@keyframes fadeInDetails {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>