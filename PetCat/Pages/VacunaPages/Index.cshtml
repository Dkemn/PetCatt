@page
@model PetCat.Pages.VacunaPages.IndexModel
@{
    ViewData["Title"] = "Historial General de Vacunas";
}

<div class="container my-5 listado-vacunas-container">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="display-5 fw-bold text-primary m-0">💉 Historial de Vacunación</h1>
            <p class="text-muted m-0">Control general de dosis aplicadas y próximos refuerzos.</p>
        </div>
        <a asp-page="Create" class="btn btn-primary btn-lg fw-semibold shadow-sm animate-scale">
            ➕ Registrar Nueva Dosis
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-vaccine-table">
                    <thead class="table-primary text-dark fw-bold">
                        <tr>
                            <th class="ps-4 py-3">@Html.DisplayNameFor(model => model.Vacuna[0].Nombre)</th>
                            <th class="py-3">Mascota / Paciente</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.Vacuna[0].FechaAplicacion)</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.Vacuna[0].FechaProximaDosis)</th>
                            <th class="text-center pe-4 py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Vacuna.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <span class="fs-2 d-block mb-2">🛡️</span>
                                    No hay registros de vacunas aplicadas en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.Vacuna)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">
                                        🧪 @Html.DisplayFor(model => item.Nombre)
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-3 py-2 fw-semibold">
                                            🐶 @item.Mascota.Nombre
                                        </span>
                                    </td>
                                    <td class="text-secondary">
                                        📅 @Html.DisplayFor(model => item.FechaAplicacion)
                                    </td>
                                    <td>
                                        <span class="badge bg-warning text-dark px-2 py-1">
                                            🗓️ @Html.DisplayFor(model => item.FechaProximaDosis)
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary px-3" title="Editar">
                                                ✏️ Editar
                                            </a>
                                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info px-3 text-dark" title="Detalles">
                                                🔍 Ver Info
                                            </a>
                                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger px-3" title="Eliminar">
                                                ❌ Borrar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="text-start mt-4">
        <a asp-page="/Index" class="text-decoration-none text-muted small">← Volver al Panel Principal</a>
    </div>

</div>

<style>
    /* Animación de entrada para el listado */
    .listado-vacunas-container {
        animation: fadeInVaccineList 0.4s ease-out;
    }

    /* Modificaciones sobre las filas de la tabla */
    .custom-vaccine-table tbody tr {
        transition: background-color 0.2s ease-in-out;
    }

        /* Hover en tonos azulados tenues */
        .custom-vaccine-table tbody tr:hover {
            background-color: #f6f9fe !important;
        }

    /* Redondear esquinas del grupo de botones */
    .btn-group .btn:first-child {
        border-top-left-radius: 6px;
        border-bottom-left-radius: 6px;
    }

    .btn-group .btn:last-child {
        border-top-right-radius: 6px;
        border-bottom-right-radius: 6px;
    }

    /* Animación de hover suave para el botón de registro */
    .animate-scale:hover {
        transform: scale(1.02);
        transition: transform 0.2s ease-in-out;
    }

    /* Doble @@ para escapar el motor Razor de ASP.NET Core */
    @@keyframes fadeInVaccineList {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>